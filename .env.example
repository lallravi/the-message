# --- Database (Postgres) ---
# Free options: Neon (neon.tech), Vercel Postgres, Supabase, Railway.
# Use the same URL for local dev and production, or a separate dev branch.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret
AUTH_SECRET=
# Base URL of the app, used to build links (e.g. email verification links).
# Set this to your real domain in production (e.g. https://themessage.church).
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs (add both dev and prod):
#   http://localhost:3000/api/auth/callback/google
#   https://<your-production-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (Resend) ---
# https://resend.com/api-keys — if left blank, verification links are
# logged to the server console instead of emailed (fine for local dev,
# but required in production so users actually receive the email).
RESEND_API_KEY=
EMAIL_FROM="The Message <onboarding@resend.dev>"

# --- Admin ---
# The email address that should automatically become the site admin the
# first time it signs up (via Google or email/password).
ADMIN_EMAIL=

# --- File storage (audio uploads) ---
# Local dev: leave blank, files are written to /public/uploads.
# Production: required — serverless hosts have no persistent disk.
# Create a store at https://vercel.com/dashboard/stores and copy its token.
BLOB_READ_WRITE_TOKEN=
